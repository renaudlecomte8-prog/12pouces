---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "12 Pouces — Atelier Cycle Participatif & Familial",
  description = "Atelier d'auto-réparation vélo participatif et familial dans le 12e arrondissement de Paris. 1 à 2 fois par mois au Kiosque Citoyen, Place Félix Eboué.",
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
